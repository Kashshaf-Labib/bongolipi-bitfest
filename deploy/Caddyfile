# Automatic HTTPS via sslip.io hostnames that resolve to the VM's public IP.
# VM_IP is injected from the environment (e.g. 140.238.1.2).

model.{$VM_IP}.sslip.io {
	reverse_proxy model:7860
}

rag.{$VM_IP}.sslip.io {
	reverse_proxy server:8000
}

collab.{$VM_IP}.sslip.io {
	reverse_proxy collab:1234
}
