# Public IP of the VM, written with dots (used to build sslip.io hostnames).
VM_IP=

# Groq API key (used by the RAG server).
GROQ_API_KEY=

# Must match COLLAB_SECRET in the Next.js app (Vercel / .env.local).
COLLAB_SECRET=

# MongoDB connection (same Atlas cluster as the app) for the collab server.
MONGODB_URI=
DBNAME=bongolipi

# Fine-tuned model on the HF Hub.
MODEL_ID=kashshaf-labib/banglish-bangla-mbart

# Comma-separated allowed origins for CORS on the model + RAG services.
# Use your Vercel domain (and http://localhost:3000 for local dev). "*" for quick testing.
ALLOWED_ORIGINS=*
