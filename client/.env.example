# MongoDB
MONGODB_URI=
DBNAME=bongolipi

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Send new sign-ups through the page that syncs the user into MongoDB.
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/after-sign-up

# Groq (LLM + Whisper)
GROQ_API_KEY=

# OpenAI (only needed if /api/upload-audio uses OpenAI Whisper)
OPENAI_API_KEY=

# RAG (FastAPI) service base URL
NEXT_PUBLIC_PDF_QUERY_URL=http://localhost:8000

# Optional custom Banglish->Bangla model service.
# If unset, the converter falls back to the Groq-backed /api/translate.
NEXT_PUBLIC_BANGLISH_API=
